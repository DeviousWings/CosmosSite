---
import getSubstackPosts from "../utils/getSubstackPosts.js";

const posts = (await getSubstackPosts()).slice(0, 3);
---

<section id="substack-preview">
  <h2>&#128233; Latest Space Posts</h2>
  <div id="space-posts">
    {posts.length === 0 ? (
      <p>No space-related posts found.</p>
    ) : (
      posts.map(post => (
        <article class="substack-card">
          <h3><a href={post.slug} target="_blank">{post.title}</a></h3>
          <p><em>{new Date(post.date).toLocaleDateString()}</em></p>
          <p>{post.description.slice(0, 150)}...</p>
        </article>
      ))
    )}
  </div>
</section>
