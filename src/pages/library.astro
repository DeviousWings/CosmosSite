---
import Layout from "../layouts/Layout.astro";
import fetchNasaAPOD from "../utils/fetchNasaAPOD";
import fetchMarsPhotos from "../utils/fetchMarsRoverPhotos";
import fetchJWSTData from "../utils/fetchJWSTData";
import fetchSpaceNews from "../utils/fetchSpaceNews";
import fetchUpcomingLaunches from "../utils/fetchUpcomingLaunches";
import fetchUpcomingEvents from "../utils/fetchUpcomingEvents";

let apod = null;
let marsPhotos = [];
let jwst = null;
let spaceNews = [];
let launches = [];
let spaceEvents = [];

try { apod = await fetchNasaAPOD(); } catch (e) { console.error("APOD fetch failed:", e.message); }
try { marsPhotos = await fetchMarsPhotos(); } catch (e) { console.error("Mars fetch failed:", e.message); }
try { jwst = await fetchJWSTData(); } catch (e) { console.error("JWST fetch failed:", e.message); }
try { spaceNews = await fetchSpaceNews(); } catch (e) { console.error("Space news fetch failed:", e.message); }
try { launches = await fetchUpcomingLaunches(8); } catch (e) { console.error("Launches fetch failed:", e.message); }
try { spaceEvents = await fetchUpcomingEvents(6); } catch (e) { console.error("Events fetch failed:", e.message); }
---

<Layout title="Library | Cosmos Library">
  <section class="library-section">
    <h1>🛰️ The Cosmos Library</h1>
    <p>Dive into curated content on space missions, open APIs, telescope data, and more. This page will evolve to showcase real-time integrations and long-form research.</p>
    <div class="library-grid custom-layout">
      <!-- LEFT COLUMN: APOD + JWST stacked -->
      <div class="left-card-group">
        <div class="library-card large-card">
          <h2>🌌 Astronomy Picture of the Day</h2>
          {apod ? (
            <>
              {apod.media_type === "video" ? (
                <iframe src={apod.url} title={apod.title} width="100%" height="300" allowfullscreen style="border-radius: 10px; border: none;" />
              ) : (
                <img src={apod.url} alt={apod.title} />
              )}
              <h3>{apod.title}</h3>
              <p>{apod.explanation.slice(0, 300)}...</p>
              <a href="https://apod.nasa.gov/apod/astropix.html" target="_blank" rel="noopener noreferrer">Read full description →</a>
            </>
          ) : (
            <p>Unable to load today's image. Try again later.</p>
          )}
        </div>

        <div class="library-card large-card">
          <h2>🔭 James Webb Space Telescope</h2>
          {jwst ? (
            <>
              <img src={jwst.image_url} alt={jwst.title} />
              <h3>{jwst.title}</h3>
              <p>{jwst.description?.slice(0, 150)}...</p>
            </>
          ) : (
            <p>JWST data unavailable right now. Try again later.</p>
          )}
        </div>
      </div>

      <!-- RIGHT COLUMN: NEO -->
      <div class="side-card-group">
        <div class="library-card small-card">
          <h2>☄️ Near Earth Objects — Today</h2>
          {marsPhotos.length > 0 ? (
            <ul class="neo-list">
              {marsPhotos.map((neo) => (
                <li class={`neo-item${neo.hazardous ? " hazardous" : ""}`}>
                  <strong>{neo.name}</strong>
                  {neo.hazardous && <span class="hazard-badge">⚠️ Hazardous</span>}
                  <small>Diameter: {neo.diameter_min}–{neo.diameter_max} m</small>
                  <small>Miss distance: {neo.miss_distance_km} km</small>
                  <small>Velocity: {neo.velocity_kph} km/h</small>
                </li>
              ))}
            </ul>
          ) : (
            <p>Near Earth Object data unavailable right now. Try again later.</p>
          )}
        </div>
      </div>
    </div>

  <!-- Space News Section -->
  <h2 class="news-heading">📰 Latest Space News</h2>
  <div class="library-grid news-row">
    {spaceNews.length > 0 ? (
      spaceNews.map((article) => (
        <a href={article.url} target="_blank" rel="noopener noreferrer" class="library-card small-card news-link">
          {article.image_url && <img src={article.image_url} alt={article.title} />}
          <span class="news-source">{article.news_site}</span>
          <h3>{article.title}</h3>
          <p>{article.summary?.slice(0, 120)}...</p>
          <small>{article.published_at}</small>
        </a>
      ))
    ) : (
      <p>Space news unavailable right now. Try again later.</p>
    )}
  </div>

  <!-- Upcoming Launches Section -->
  <h2 class="news-heading">🚀 Upcoming Launches</h2>
  <div class="launches-list">
    {launches.length > 0 ? (
      launches.map((launch) => (
        <div class="launch-row">
          {launch.image && (
            <img class="launch-row-img" src={launch.image} alt={launch.name} />
          )}
          <div class="launch-row-info">
            <div class="launch-row-top">
              <span class="launch-status-badge">{launch.status}</span>
              <span class="launch-row-rocket">🛸 {launch.rocket}</span>
            </div>
            <h3 class="launch-row-name">{launch.name}</h3>
            {launch.pad && (
              <p class="launch-row-pad">📍 {launch.pad}{launch.location ? `, ${launch.location}` : ""}</p>
            )}
            <p class="launch-row-time">
              🗓 {new Date(launch.net).toLocaleString("en-US", {
                month: "short", day: "numeric", year: "numeric",
                hour: "2-digit", minute: "2-digit", timeZoneName: "short"
              })}
            </p>
          </div>
        </div>
      ))
    ) : (
      <p>Launch schedule unavailable right now. Try again later.</p>
    )}
    {launches.length > 0 && (
      <div class="space-devs-footer">
        <a href="https://thespacedevs.com/launches" target="_blank" rel="noopener noreferrer" class="space-devs-link">
          🔴 Live updates &amp; full schedule on The Space Devs →
        </a>
        <span class="cache-note">Launch data refreshes daily at 6 AM UTC</span>
      </div>
    )}
  </div>

  <!-- Space Events Section -->
  <h2 class="news-heading">🛸 Upcoming Space Events</h2>
  <div class="launches-list">
    {spaceEvents.length > 0 ? (
      spaceEvents.map((event) => (
        <div class="launch-row">
          {event.image && (
            <img class="launch-row-img" src={event.image} alt={event.name} />
          )}
          <div class="launch-row-info">
            <div class="launch-row-top">
              <span class="launch-status-badge event-type-badge">{event.type}</span>
            </div>
            <h3 class="launch-row-name">{event.name}</h3>
            {event.location && (
              <p class="launch-row-pad">📍 {event.location}</p>
            )}
            {event.description && (
              <p class="launch-row-desc">{event.description.slice(0, 160)}...</p>
            )}
            <p class="launch-row-time">
              🗓 {new Date(event.date).toLocaleString("en-US", {
                month: "short", day: "numeric", year: "numeric",
                hour: "2-digit", minute: "2-digit", timeZoneName: "short"
              })}
            </p>
            {(event.video_url || event.news_url) && (
              <div class="event-links">
                {event.video_url && <a href={event.video_url} target="_blank" rel="noopener noreferrer">▶ Watch</a>}
                {event.news_url && <a href={event.news_url} target="_blank" rel="noopener noreferrer">📰 Read more</a>}
              </div>
            )}
          </div>
        </div>
      ))
    ) : (
      <p>Space events unavailable right now. Try again later.</p>
    )}
  </div>

  </section>

</Layout>
